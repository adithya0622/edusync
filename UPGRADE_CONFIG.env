# UPGRADE_CONFIG.env - Configuration file for Upgrade application
# Copy this to .env and modify as needed

# ==================== Backend Configuration ====================

# Backend server settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_ENV=development

# API Configuration
API_TITLE=Drop In - Student Learning Recommendation System
API_VERSION=1.0.0

# File paths (relative to backend folder)
STUDENTS_FILE=../Students.xlsx
COURSES_FILE=../Courses.xlsx

# CORS settings
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3001

# ==================== Frontend Configuration ====================

# Frontend server settings
FRONTEND_PORT=5173
FRONTEND_HOST=localhost

# API endpoint
REACT_APP_API_URL=http://localhost:8000

# ==================== ML Configuration ====================

# ML Model parameters
ML_K_VALUE=30
ML_RANDOM_STATE=42

# ==================== Logging ====================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==================== Database ====================

# Excel file settings
EXCEL_CACHE_ENABLED=true
EXCEL_CACHE_DURATION=3600

# ==================== Security ====================

# JWT / Password settings
DEMO_PASSWORD=demo123
JWT_SECRET=dropin-jwt-secret-2026-change-in-prod
JWT_ALGORITHM=HS256
TOKEN_EXPIRE_HOURS=8
ROLL_ENCRYPT_SECRET=dropin-rollno-key-2026
TEACHER_EMAIL=teacher123@gmail.com

# Production settings
DEBUG=true
SECURE_MODE=false

# ==================== App Server ====================

APP_HOST=0.0.0.0
APP_PORT=8080
APP_TITLE=Drop In - Student Learning Recommendation System

# ==================== Performance Thresholds ====================
# Fraction of max possible marks for each performance band

PERF_EXCELLENT=0.80
PERF_VERY_GOOD=0.60
PERF_GOOD=0.40
PERF_SATISFACTORY=0.20
FALLBACK_MAX_MARKS=250

# Below this fraction of max marks a recommendation strategy is triggered
RECO_THRESHOLD=0.60

# ==================== Peer Matching ====================

BUDDY_WEAK_THRESHOLD=0.60
BUDDY_STRONG_THRESHOLD=0.70

# ==================== Gamification ====================

XP_PER_LEVEL=50
MAX_LEVEL=20
MASTERY_PCT=0.80

# ==================== Wellness / Burnout ====================

BURNOUT_HIGH_THRESHOLD=60
BURNOUT_MODERATE_THRESHOLD=35

# ==================== Performance Forecasting ====================

FORECAST_A_THRESHOLD=80
FORECAST_B_THRESHOLD=65
FORECAST_C_THRESHOLD=50

# ==================== Feature Flags ====================

# Enable/disable features
ENABLE_RECOMMENDATIONS=true
ENABLE_ML_MODELS=true
ENABLE_ADMIN_ENDPOINTS=true
